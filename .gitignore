# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# electron build outputs
/dist
/dist-electron

# misc
.DS_Store
*.pem
!public/license/public-key.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
/public/workbox-*.js
public/sw.js

.idea
.next
.DS_Store
.env
.gitignore.swp
public/sw.js.map

# Code signing certificate (sensitive — never commit)
build/signing/cert.pfx
build/signing/*.pem
build/signing/*.key

# Icon generation temp files
.ico-tmp/

# Electron build output
dist-electron/

# E2E test database
.test-db/

# Local tool caches - (e.g. better-sqlite3 prebuilds)
.cache/
