{
  "name": "posman-app",
  "version": "0.1.68",
  "private": true,
  "type": "module",
  "description": "JK POSMAN",
  "scripts": {
    "tsc": "tsc --noEmit",
    "dev": "next dev",
    "build": "cross-env NODE_OPTIONS=--max-old-space-size=8192 next build",
    "start": "NODE_ENV=production next start",
    "lint": "next lint",
    "test": "npm run test:unit && npm run test:e2e",
    "migration:generate": "typeorm-ts-node-commonjs migration:generate -d src/backend/config/data-source.ts",
    "migration:run": "NODE_OPTIONS=\"--loader ts-node/esm\" node src/backend/config/run-migrations.ts",
    "migration:revert": "typeorm-ts-node-commonjs migration:revert -d src/backend/config/data-source.ts",
    "migration:show": "typeorm-ts-node-commonjs migration:show -d src/backend/config/data-source.ts",
    "electron:dev": "PORT=3000 electron electron/main.cjs",
    "electron:dev:sqlite": "PORT=3000 DB_MODE=sqlite electron electron/main.cjs",
    "electron:build": "node scripts/build-electron.js",
    "electron:build:win": "node scripts/build-electron.js win",
    "electron:build:mac": "node scripts/build-electron.js mac",
    "electron:build:linux": "node scripts/build-electron.js linux",
    "electron:build:sqlite": "cross-env DB_MODE=sqlite node scripts/build-electron.js",
    "electron:build:sqlite:win": "cross-env DB_MODE=sqlite node scripts/build-electron.js win",
    "electron:build:sqlite:mac": "cross-env DB_MODE=sqlite node scripts/build-electron.js mac",
    "electron:build:sqlite:linux": "cross-env DB_MODE=sqlite node scripts/build-electron.js linux",
    "electron:pack": "electron-builder",
    "electron:pack:win": "electron-builder --win",
    "electron:pack:mac": "electron-builder --mac",
    "electron:pack:linux": "electron-builder --linux",
    "electron:publish:win": "GH_TOKEN=$GH_TOKEN node scripts/build-electron.js win --publish",
    "electron:publish:mac": "GH_TOKEN=$GH_TOKEN node scripts/build-electron.js mac --publish",
    "generate:icons": "node scripts/generate-icons.mjs",
    "generate:cert": "node scripts/generate-self-signed-cert.cjs",
    "test:e2e": "vitest run --config vitest.config.e2e.ts",
    "test:e2e:watch": "vitest --config vitest.config.e2e.ts",
    "test:e2e:coverage": "vitest run --config vitest.config.e2e.ts --coverage",
    "test:unit": "vitest run --config vitest.config.unit.ts",
    "test:unit:watch": "vitest --config vitest.config.unit.ts",
    "test:unit:coverage": "vitest run --config vitest.config.unit.ts --coverage",
    "electron:build:win:x86": "node scripts/build-electron.js win --arch=ia32",
    "electron:build:sqlite:win:x86": "cross-env DB_MODE=sqlite node scripts/build-electron.js win --arch=ia32",
    "electron:build:win:nsis-both": "cross-env WIN_ARCH=all node scripts/build-electron.js win",
    "electron:build:sqlite:win:nsis-both": "cross-env DB_MODE=sqlite WIN_ARCH=all node scripts/build-electron.js win"
  },
  "dependencies": {
    "@types/formidable": "^3.4.6",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.9.0",
    "bootstrap": "^5.3.3",
    "bootstrap-icons": "^1.13.1",
    "class-transformer": "^0.5.1",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "dotenv": "^16.6.1",
    "electron-updater": "^6.8.3",
    "express": "^4.21.0",
    "formidable": "^3.5.4",
    "glob": "^11.0.3",
    "jsonwebtoken": "^9.0.2",
    "keytar": "^7.9.0",
    "moment": "^2.30.1",
    "mysql2": "^3.11.3",
    "next": "15.2.8",
    "next-connect": "^1.0.0-next.4",
    "next-pwa": "^5.6.0",
    "next-swagger-doc": "^0.4.1",
    "node-cache": "^5.1.2",
    "node-fetch": "^3.3.2",
    "papaparse": "^5.5.3",
    "pino": "^9.9.5",
    "pino-pretty": "^13.1.1",
    "png-to-ico": "^3.0.1",
    "process": "^0.11.10",
    "react": "^18.3.1",
    "react-bootstrap": "^2.10.5",
    "react-datepicker": "^7.5.0",
    "react-day-picker": "^9.1.4",
    "react-dom": "^18.3.1",
    "react-select": "^5.8.1",
    "reflect-metadata": "^0.2.2",
    "swagger-ui-react": "^5.21.0",
    "typedi": "^0.10.0",
    "typeorm": "^0.3.19",
    "workbox-webpack-plugin": "^7.1.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/bootstrap": "^5.2.10",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/next": "^9.0.0",
    "@types/node": "^22",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.28.0",
    "@typescript-eslint/parser": "^8.8.1",
    "@vitest/coverage-v8": "^3.2.4",
    "cross-env": "^10.1.0",
    "electron": "^39.2.7",
    "electron-builder": "^26.0.12",
    "eslint": "^8",
    "eslint-config-next": "^14.2.5",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-react": "^7.37.1",
    "next-test-api-route-handler": "^5.0.4",
    "prettier": "^3.3.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^3.2.4"
  },
  "main": "electron/main.cjs"
}
