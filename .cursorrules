export default function MyPage() {
  return (
    <AdminLayout authError={null}>
      <div className="container-fluid">
        {/* Page content */}
      </div>
    </AdminLayout>
  );
}

// ✅ CORRECT Usage with Parent Layout (e.g., /home/cashier/* pages)
// Parent layout already provides RoleAwareLayout
export default function CashierBillsPage() {
  return (
    <div className="container-fluid">
      {/* Page content - no RoleAwareLayout needed */}
    </div>
  );
}

// ❌ WRONG Usage with Parent Layout (creates duplicate navigation)
import RoleAwareLayout from "../shared/RoleAwareLayout";

export default function CashierBillsPage() {
  return (
    <RoleAwareLayout>  {/* WRONG - parent already provides this */}
      <div className="container-fluid">
        {/* Page content */}
      </div>
    </RoleAwareLayout>
  );
}
```

### Rule 5.9: Layout Hierarchy
- **ALWAYS** check if a page is already wrapped by a parent layout before adding `RoleAwareLayout`
- **ALWAYS** use parent layouts when available (e.g., `CashierLayout` for `/home/cashier/*` pages)
- **NEVER** create duplicate navigation bars by nesting layouts

