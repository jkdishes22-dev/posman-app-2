{
  "compilerOptions": {
    "noEmitOnError": true,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "baseUrl": ".",
    "paths": {
      "@backend/*": [
        "src/backend/*"
      ],
      "@entities/*": [
        "src/backend/entities/*"
      ],
      "@services/*": [
        "src/backend/service/*"
      ],
      "@repos/*": [
        "src/backend/repos/*"
      ],
      "@controllers/*": [
        "src/backend/controllers/*"
      ],
      "@interfaces/*": [
        "src/backend/interfaces/*"
      ]
    },
    "plugins": [
      {
        "name": "next"
      }
    ],
    "target": "ES2017"
  },
  "typeRoots": [
    "./node_modules/@types",
    "./src/backend/types"
  ],
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "**/**/*.ts",
    "**/**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "migration-backups"
  ]
}